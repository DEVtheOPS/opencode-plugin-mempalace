  "description": "MemPalace plugin for OpenCode. Installs the Python package, registers the MCP server, and injects commands and a bundled skill.",
  "type": "module",
  "author": "DEVtheOPS",
  "license": "MIT",
  "homepage": "https://github.com/DEVtheOPS/opencode-mempalace#readme",
  "repository": {
    "type": "git",
